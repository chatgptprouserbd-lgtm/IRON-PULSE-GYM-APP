<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
    <title>IRON PULSE | Background Edition</title>
    <style>
        :root { --neon: #39FF14; --dark: #070707; }
        body { font-family: 'Rajdhani', sans-serif; background-color: var(--dark); color: white; min-height: 100vh; overflow-x: hidden; }
        .neon-text { font-family: 'Orbitron', sans-serif; color: var(--neon); text-shadow: 0 0 20px rgba(57, 255, 20, 0.4); }
        .glass-panel { background: rgba(20, 20, 20, 0.6); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .neon-btn { background: var(--neon); color: black; font-weight: 900; text-transform: uppercase; clip-path: polygon(8% 0, 100% 0, 92% 100%, 0 100%); transition: 0.3s; cursor: pointer; border: none; }
        .neon-btn:hover { box-shadow: 0 0 25px var(--neon); transform: scale(1.02); }
        .modal-blur { background: rgba(0,0,0,0.9); backdrop-filter: blur(15px); }
        input, select { background: rgba(255,255,255,0.05) !important; border: 1px solid rgba(255,255,255,0.1) !important; color: white !important; outline: none !important; }
        select option { background-color: #111 !important; color: white !important; }
        .profile-img-dashboard { width: 60px; height: 60px; border-radius: 18px; object-fit: cover; border: 2px solid var(--neon); }
        .hidden { display: none !important; }
        .day-btn-active { border: 2px solid var(--neon) !important; color: var(--neon) !important; }
    </style>
</head>
<body class="p-4 md:p-8">

    <div id="auth-section" class="max-w-md mx-auto mt-12">
        <div id="signup-box" class="glass-panel p-8 rounded-[40px]">
            <h1 class="text-5xl neon-text text-center mb-8 italic font-black">IRON PULSE</h1>
            <div class="space-y-4">
                <input id="reg-name" type="text" placeholder="FULL NAME" class="w-full p-4 rounded-2xl">
                <input id="reg-user" type="text" placeholder="USERNAME" class="w-full p-4 rounded-2xl">
                <div class="flex gap-3">
                    <input id="reg-pin" type="password" maxlength="4" placeholder="4-PIN" class="w-1/3 p-4 rounded-2xl text-center font-bold text-xl">
                    <input id="reg-pass" type="password" placeholder="PASSWORD" class="w-2/3 p-4 rounded-2xl">
                </div>
                <button onclick="handleCloudSignup()" class="w-full neon-btn py-5 mt-4">Initialize Engine</button>
            </div>
            <p class="mt-6 text-center text-zinc-500 text-xs tracking-widest cursor-pointer" onclick="toggleAuth(false)">EXISTING USER? LOGIN</p>
        </div>

        <div id="login-box" class="hidden glass-panel p-10 rounded-[40px] text-center">
            <h1 class="text-3xl neon-text mb-10 italic uppercase font-black">System Auth</h1>
            <div class="space-y-6">
                <input id="log-user" type="text" class="w-full p-4 rounded-2xl text-center bg-black opacity-60" readonly>
                <input id="log-pin" type="password" maxlength="4" placeholder="----" class="w-full p-5 rounded-2xl text-center text-4xl tracking-[20px] font-black text-lime-400">
                <button onclick="handlePinLogin()" class="w-full neon-btn py-5">ACCESS DASHBOARD</button>
            </div>
            <p class="mt-8 text-zinc-500 text-xs cursor-pointer uppercase" onclick="clearUserMemory()">Switch Account</p>
        </div>
    </div>

    <div id="dashboard" class="hidden max-w-6xl mx-auto">
        <header class="flex flex-wrap justify-between items-center mb-10 bg-zinc-900/40 p-5 rounded-[30px] border border-zinc-800 gap-4">
            <div class="flex items-center gap-5">
                <img id="display-pic" src="" class="profile-img-dashboard">
                <div>
                    <h2 id="user-display-name" class="text-3xl font-black uppercase italic neon-text"></h2>
                    <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-[4px]">V10 Cloud Edition</p>
                </div>
            </div>
            <div class="flex gap-3">
                <button onclick="openAlertSetup()" class="bg-blue-600/10 text-blue-400 px-6 py-3 rounded-2xl text-[11px] font-black border border-blue-500/30 uppercase">Setup Alert 🔔</button>
                <button onclick="openSettings()" class="bg-zinc-800 p-4 rounded-2xl border border-zinc-700">⚙️</button>
                <button onclick="handleLogout()" class="bg-red-900/10 text-red-500 px-6 py-3 rounded-2xl text-[11px] font-black border border-red-900/30 uppercase">Log Out</button>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-7 glass-panel p-8 rounded-[40px]">
                <div class="flex justify-between items-center mb-8"><h3 class="neon-text text-2xl italic uppercase font-black">Diet Protocol</h3><button onclick="openDietModal()" class="h-12 w-12 bg-lime-500 text-black rounded-2xl font-black text-2xl">+</button></div>
                <div id="diet-list" class="space-y-4"></div>
            </div>
            <div class="lg:col-span-5 glass-panel p-8 rounded-[40px]">
                <h3 class="text-2xl font-black text-lime-400 mb-8 uppercase italic">7-Day Cycle</h3>
                <div id="day-selector" class="flex flex-wrap gap-2 mb-8"></div>
                <div class="bg-zinc-900/60 p-8 rounded-[30px] border border-zinc-800/50">
                    <p id="current-day-label" class="text-[10px] text-zinc-500 uppercase mb-6 tracking-[5px] font-black"></p>
                    <input id="w-time" type="time" class="w-full p-4 rounded-2xl text-2xl font-black bg-black/50 mb-6">
                    <select id="w-target" class="w-full p-4 rounded-2xl uppercase font-black text-xs mb-6">
                        <option value="Push Day">Push Day</option>
                        <option value="Pull Day">Pull Day</option>
                        <option value="Leg Day">Leg Day</option>
                        <option value="Arms / Abs">Arms / Abs</option>
                        <option value="Rest Day">Rest Day</option>
                    </select>
                    <button onclick="saveWorkout()" class="w-full neon-btn py-5">Commit to Cloud</button>
                </div>
            </div>
        </div>
    </div>

    <div id="settings-modal" class="hidden fixed inset-0 modal-blur z-[800] flex items-center justify-center p-6 text-center">
        <div class="glass-panel p-10 rounded-[40px] max-w-sm w-full">
            <h2 class="neon-text text-xl mb-8 italic uppercase font-black">Identity Settings</h2>
            <input id="set-name" type="text" class="w-full p-4 rounded-xl font-bold uppercase mb-4">
            <div class="bg-black/40 p-6 rounded-3xl border border-zinc-800 mb-6 text-center">
                <input type="file" id="file-input" accept="image/*" class="hidden">
                <button type="button" onclick="document.getElementById('file-input').click()" class="text-[10px] text-lime-400 font-black border-2 border-lime-400/20 px-6 py-3 rounded-xl uppercase">Change Photo</button>
            </div>
            <div id="crop-area" class="hidden mb-4"><div style="height:150px; overflow:hidden; border-radius:20px;"><img id="image-to-crop" src=""></div></div>
            <div class="flex gap-3"><button onclick="closeSettings()" class="flex-1 bg-zinc-800 py-4 rounded-xl text-[10px] uppercase font-bold">Cancel</button><button onclick="applySettings()" class="flex-1 neon-btn py-4">Save</button></div>
        </div>
    </div>

    <div id="alert-modal" class="hidden fixed inset-0 modal-blur z-[800] flex items-center justify-center p-4">
        <div class="glass-panel p-8 rounded-[40px] max-w-lg w-full border-lime-500 border overflow-y-auto max-h-[90vh]">
            <h2 class="text-3xl neon-text italic mb-6 text-center uppercase font-black">WhatsApp Cloud</h2>
            <div class="bg-lime-500/5 p-5 rounded-3xl border border-lime-500/20 mb-6">
                <h4 class="text-lime-400 font-bold text-[12px] mb-3 uppercase font-black tracking-widest">📋 সেটআপ গাইড:</h4>
                <ul class="text-[11px] space-y-3 text-zinc-300">
                    <li>১. <span class="text-white font-bold">GET API KEY</span> ক্লিক করে WhatsApp-এ মেসেজ পাঠান।</li>
                    <li>২. বট থেকে আসা রিপ্লাইয়ে <span class="text-white">API Key (সংখ্যা)</span> পাবেন।</li>
                    <li>৩. নিচে নাম্বার (Country code সহ) এবং Key দিয়ে Save করুন।</li>
                </ul>
                <button onclick="window.open('https://wa.me/34644105544?text=I%20allow%20callmebot%20to%20send%20me%20messages')" class="w-full mt-4 bg-zinc-900 py-3 rounded-xl text-[10px] border border-zinc-700 font-bold uppercase">Get API Key</button>
            </div>
            <input id="wa-num" type="number" placeholder="8801XXXXXXXXX" class="w-full p-4 rounded-xl mb-4">
            <input id="wa-key" type="number" placeholder="ENTER API KEY" class="w-full p-4 rounded-xl mb-8">
            <div class="flex gap-4"><button onclick="closeAlertSetup()" class="flex-1 bg-zinc-800 py-4 rounded-2xl font-bold text-xs uppercase">Back</button><button onclick="saveWa()" class="flex-1 neon-btn py-4">Save</button></div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, doc, setDoc, getDoc, updateDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";
        import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

        const firebaseConfig = {
            apiKey: "AIzaSyAb3a1E3TqlS41IKlnFSZ6fM9McYZoIcmk",
            authDomain: "iron-pulse-10ab4.firebaseapp.com",
            projectId: "iron-pulse-10ab4",
            storageBucket: "iron-pulse-10ab4.firebasestorage.app",
            messagingSenderId: "76007397293",
            appId: "1:76007397293:web:9014c05ac06bf49523f324"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);

        window.handleCloudSignup = async () => {
            const name = document.getElementById('reg-name').value, user = document.getElementById('reg-user').value.trim(), pin = document.getElementById('reg-pin').value, pass = document.getElementById('reg-pass').value;
            if(!name || !user || pin.length < 4 || pass.length < 6) return alert("Fill all!");
            try {
                const res = await createUserWithEmailAndPassword(auth, `${user}@ironpulse.com`, pass);
                const data = { name, user, pin, pass, pic: "https://cdn-icons-png.flaticon.com/512/1144/1144760.png", diet: [], workout: {}, waNumber: "", waApi: "" };
                await setDoc(doc(db, "users", res.user.uid), data);
                localStorage.setItem('ironPulseUser', user); localStorage.setItem('ironPulsePass', pass);
                location.reload();
            } catch (e) { alert(e.message); }
        };

        window.handlePinLogin = async () => {
            const user = document.getElementById('log-user').value, pin = document.getElementById('log-pin').value, pass = localStorage.getItem('ironPulsePass');
            try {
                const res = await signInWithEmailAndPassword(auth, `${user}@ironpulse.com`, pass);
                const snap = await getDoc(doc(db, "users", res.user.uid));
                if(snap.data().pin === pin) { location.reload(); } else { alert("WRONG PIN!"); }
            } catch (e) { alert("Login Failed!"); }
        };

        window.handleLogout = async () => { await signOut(auth); localStorage.removeItem('ironPulsePass'); location.reload(); };

        onAuthStateChanged(auth, async (user) => {
            if (user) {
                const snap = await getDoc(doc(db, "users", user.uid));
                if(snap.exists()) {
                    window.userData = snap.data();
                    document.getElementById('user-display-name').innerText = window.userData.name;
                    document.getElementById('display-pic').src = window.userData.pic;
                    document.getElementById('auth-section').classList.add('hidden');
                    document.getElementById('dashboard').classList.remove('hidden');
                    initDashboard();
                    startBackgroundAutomation();
                }
            } else {
                const savedUser = localStorage.getItem('ironPulseUser');
                if(savedUser) { toggleAuth(false); document.getElementById('log-user').value = savedUser; }
                else { toggleAuth(true); }
            }
        });

        window.fbUpdate = async (data) => { await updateDoc(doc(db, "users", auth.currentUser.uid), data); };
    </script>

    <script>
        function toggleAuth(isSignup) { document.getElementById('signup-box').classList.toggle('hidden', !isSignup); document.getElementById('login-box').classList.toggle('hidden', isSignup); }
        function initDashboard() {
            const DAYS = ["Saturday", "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];
            const container = document.getElementById('day-selector'); container.innerHTML = "";
            DAYS.forEach(day => {
                container.innerHTML += `<button onclick="selectDay('${day}')" id="btn-${day}" class="p-4 flex-1 min-w-[70px] bg-zinc-900/60 border border-zinc-800 rounded-2xl text-[10px] font-black uppercase tracking-widest">${day.substring(0,3)}</button>`;
            });
            selectDay(new Date().toLocaleDateString('en-US', { weekday: 'long' }));
            renderDiet();
        }

        function selectDay(day) {
            window.currentDay = day;
            document.querySelectorAll('#day-selector button').forEach(b => b.classList.remove('day-btn-active'));
            if(document.getElementById(`btn-${day}`)) document.getElementById(`btn-${day}`).classList.add('day-btn-active');
            document.getElementById('current-day-label').innerText = day + " PROTOCOL";
            const saved = (window.userData.workout || {})[day] || {time: '', target: 'Push Day'};
            document.getElementById('w-time').value = saved.time;
            document.getElementById('w-target').value = saved.target;
        }

        async function saveWorkout() {
            window.userData.workout[window.currentDay] = { time: document.getElementById('w-time').value, target: document.getElementById('w-target').value };
            await window.fbUpdate({ workout: window.userData.workout }); alert("Cloud Synced!");
        }

        function renderDiet() {
            const list = document.getElementById('diet-list'); list.innerHTML = "";
            (window.userData.diet || []).forEach(i => {
                list.innerHTML += `<div class="bg-zinc-900/40 p-5 rounded-[25px] flex justify-between items-center border border-zinc-800"><div><p class="text-[10px] text-lime-400 font-black">${i.time}</p><p class="text-md font-bold uppercase italic">${i.food}</p></div><button onclick="deleteDiet(${i.id})" class="text-zinc-600 text-2xl">×</button></div>`;
            });
        }

        // --- BACKGROUND AUTOMATION (Service Worker Simulation) ---
        function startBackgroundAutomation() {
            if (!('serviceWorker' in navigator)) return;
            
            setInterval(() => {
                const now = new Date();
                const day = now.toLocaleDateString('en-US', { weekday: 'long' });
                const time = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');

                if (window.userData && window.userData.workout && window.userData.workout[day]) {
                    const workout = window.userData.workout[day];
                    if (workout.time === time && window.userData.waNumber && window.userData.waApi) {
                        const lastSent = localStorage.getItem('last_wa_sent');
                        if (lastSent !== time) {
                            const url = `https://api.callmebot.com/whatsapp.php?phone=${window.userData.waNumber}&text=🚨+*IRON+PULSE+ALERT!*+%0A%0ABhai,+ekhon+apnar+*${workout.target.toUpperCase()}*+er+somoy!+💪&apikey=${window.userData.waApi}`;
                            fetch(url, { mode: 'no-cors' });
                            localStorage.setItem('last_wa_sent', time);
                        }
                    }
                }
            }, 30000); // 30 sec check
        }

        // Settings Fixes
        let cropper;
        document.getElementById('file-input').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    const img = document.getElementById('image-to-crop'); img.src = event.target.result;
                    document.getElementById('crop-area').classList.remove('hidden');
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(img, { aspectRatio: 1, viewMode: 1 });
                };
                reader.readAsDataURL(file);
            }
        });

        async function applySettings() {
            let updates = { name: document.getElementById('set-name').value };
            if(cropper) updates.pic = cropper.getCroppedCanvas({width:400,height:400}).toDataURL("image/png");
            await window.fbUpdate(updates); location.reload();
        }

        async function saveWa() { await window.fbUpdate({ waNumber: document.getElementById('wa-num').value, waApi: document.getElementById('wa-key').value }); alert("Saved!"); closeAlertSetup(); }
        function openSettings() { document.getElementById('settings-modal').classList.remove('hidden'); document.getElementById('set-name').value = window.userData.name; }
        function closeSettings() { document.getElementById('settings-modal').classList.add('hidden'); }
        function openAlertSetup() { document.getElementById('alert-modal').classList.remove('hidden'); }
        function closeAlertSetup() { document.getElementById('alert-modal').classList.add('hidden'); }
    </script>
</body>
</html>
